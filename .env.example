# =============================================================================
# AI Auto-Responder Configuration
# =============================================================================

# Anthropic API key for Claude LLM used by pydantic-ai agent.
# Get one from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Model name to use for the auto-responder agent.
# See available models at: https://docs.anthropic.com/en/docs/about-claude/models
ANTHROPIC_MODEL=claude-sonnet-4-6

# =============================================================================
# Application Configuration
# =============================================================================

# Environment: development | staging | production
APP_ENV=development

# Host and port the FastAPI server binds to.
APP_HOST=0.0.0.0
APP_PORT=8000

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Secret key used for signing sessions / JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=replace-with-a-long-random-string

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL connection URL for ticket persistence.
# Format: postgresql+asyncpg://user:password@host:port/database
# For local dev with Docker: postgresql+asyncpg://postgres:postgres@localhost:5432/support_tickets
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/support_tickets

# =============================================================================
# Auto-Responder Behavior
# =============================================================================

# Confidence threshold (0.0–1.0). Tickets where the agent's confidence is below
# this value will be escalated to a human agent instead of auto-replied.
CONFIDENCE_THRESHOLD=0.75

# Maximum number of tool-call iterations the agent may perform per ticket.
MAX_AGENT_ITERATIONS=5

# Categories that should ALWAYS be escalated to a human, comma-separated.
# Example: billing_dispute,legal,security_incident
ALWAYS_ESCALATE_CATEGORIES=billing_dispute,legal,security_incident,refund_over_threshold

# Refund amount (in USD) above which tickets require human approval.
REFUND_AUTO_APPROVE_LIMIT=50.00

# =============================================================================
# Email / Notification Provider (SendGrid)
# =============================================================================

# SendGrid API key for sending automated replies to customers.
# Get one from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# Verified sender email address configured in SendGrid.
# Configure at: https://app.sendgrid.com/settings/sender_auth
SUPPORT_FROM_EMAIL=support@yourdomain.com
SUPPORT_FROM_NAME=Acme Support

# =============================================================================
# Human Handoff / Agent Notification (Slack)
# =============================================================================

# Slack Incoming Webhook URL — posts escalated tickets to a support channel.
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/PATH

# Slack channel name used in webhook messages (informational).
SLACK_HANDOFF_CHANNEL=#support-escalations

# =============================================================================
# Knowledge Base / Vector Store (optional, for RAG over help docs)
# =============================================================================

# OpenAI API key used for embedding help-center articles into the vector store.
# Get one from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Embedding model name.
# See: https://platform.openai.com/docs/guides/embeddings
EMBEDDING_MODEL=text-embedding-3-small

# Path to the local Chroma vector store directory.
CHROMA_PERSIST_DIR=./data/chroma

# =============================================================================
# CRM Integration (optional — for fetching customer context)
# =============================================================================

# HubSpot private app access token used to look up customer profile + order history.
# Create a private app at: https://developers.hubspot.com/docs/api/private-apps
HUBSPOT_ACCESS_TOKEN=pat-na1-your-hubspot-token-here

# =============================================================================
# Rate Limiting & Observability
# =============================================================================

# Redis URL used for rate limiting and idempotency keys.
# Local default: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Logfire write token for tracing pydantic-ai agent runs.
# Get one from: https://logfire.pydantic.dev/ (project → Settings → Write Tokens)
LOGFIRE_TOKEN=your-logfire-write-token-here

# Toggle Logfire instrumentation: true | false
LOGFIRE_ENABLED=true